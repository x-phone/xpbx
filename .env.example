# xpbx environment configuration
# Copy to .env and adjust as needed.

# Host IP for SIP NAT/RTP — tells Asterisk where phones should send media.
# Auto-detected via STUN if not set (works for cloud/VPS).
# Set explicitly for Tailscale, VPN, or LAN-only setups.
# EXTERNAL_IP=100.96.49.117

# Web UI listen address
# XPBX_LISTEN_ADDR=:8080

# SQLite database path (shared with Asterisk)
# XPBX_DB_PATH=/data/asterisk-realtime.db

# Asterisk REST Interface (ARI) connection
# ARI_HOST=asterisk
# ARI_PORT=8088
# ARI_USER=xpbx
# ARI_PASSWORD=secret

# Logging level: debug, info, warn, error
# LOG_LEVEL=info
